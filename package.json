{
	"name": "budbot",
	"version": "3.1.0",
	"description": "Discord bot for the Joint Streaming Community.",
	"type": "module",
	"main": "dist/Structures/client/index.js",
	"scripts": {
		"build": "tsc",
		"tsc:watch": "tsc -w",
		"start/dev": "tsc && nodemon ./dist/Structures/client/index.js",
		"start/node": "tsc && node ./dist/Structures/client/index.js"
	},
	"keywords": [
		"typescript",
		"sern",
		"discord.js",
		"economy"
	],
	"license": "UNLICENSED",
	"dependencies": {
		"@sern/handler": "^3.0.3",
		"@spark.ts/logger": "^1.4.0",
		"axios": "^1.4.0",
		"canvas": "^2.11.2",
		"chalk": "^5.3.0",
		"colorette": "^2.0.20",
		"discord.js": "^14.12.1",
		"mongoose": "^7.4.3"
	},
	"devDependencies": {
		"@types/node": "^20.5.0",
		"typescript": "^5.1.6"
	},
	"imports": {
		"#utils": [
			"./dist/Structures/utils/index.js"
		],
		"#plugins": [
			"./dist/Structures/plugins/index.js"
		],
		"#BudBot": [
			"./dist/Structures/client/BudBot.js"
		],
		"#schemas/*": [
			"./dist/Structures/schemas/*.js"
		]
	}
}
